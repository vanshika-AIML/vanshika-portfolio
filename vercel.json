{
  "buildCommand": "cd portfolio-react && npm run build",
  "outputDirectory": "portfolio-react/dist",
  "installCommand": "cd portfolio-react && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assests/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
